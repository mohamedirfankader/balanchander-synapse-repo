{
	"name": "Pipeline 2",
	"properties": {
		"activities": [
			{
				"name": "Notebook1",
				"type": "SynapseNotebook",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"notebook": {
						"referenceName": "Notebook 1",
						"type": "NotebookReference"
					},
					"snapshot": true,
					"sparkPool": {
						"referenceName": "izspark",
						"type": "BigDataPoolReference"
					},
					"executorSize": "Small",
					"conf": {
						"spark.dynamicAllocation.enabled": true,
						"spark.dynamicAllocation.minExecutors": 1,
						"spark.dynamicAllocation.maxExecutors": 4
					},
					"driverSize": "Small",
					"numExecutors": 1,
					"authentication": {
						"type": "MSI"
					}
				}
			},
			{
				"name": "SQL pool stored procedure1",
				"type": "SqlPoolStoredProcedure",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"sqlPool": {
					"referenceName": "we47dedpool",
					"type": "SqlPoolReference"
				},
				"typeProperties": {
					"storedProcedureName": "[bank_schema].[sp_retail_curation]",
					"storedProcedureParameters": {
						"ProcessType": {
							"value": {
								"value": "@pipeline().parameters.spparam",
								"type": "Expression"
							},
							"type": "String"
						}
					}
				}
			}
		],
		"parameters": {
			"spparam": {
				"type": "string",
				"defaultValue": "INSERT"
			}
		},
		"annotations": []
	}
}