				"source": [
					"## Reading Data from Synapse"
				]
			},
			{
				"cell_type": "code",
				"metadata": {
					"collapsed": false
				},
				"source": [
					"# 1. Add required imports to bind 'synapsesql' to the Spark session\n",
					"import com.microsoft.spark.sqlanalytics\n",
					"from com.microsoft.spark.sqlanalytics.Constants import Constants\n",
					"\n",
					"# 2. Define your table reference (<DatabaseName>.<SchemaName>.<TableName>)\n",
					"dedicated_table = \"dedsqlwh.dbo.tbl1\"\n",
					"\n",
					"# 3. Read the dedicated table into a Spark DataFrame\n",
					"df = spark.read.synapsesql(dedicated_table)\n",
					"\n",
					"# 4. Show data\n",
					"display(df.limit(10))"
				],
				"execution_count": 9
			},
			{
				"cell_type": "markdown",
				"metadata": {
					"nteract": {
						"transient": {
							"deleting": false
						}
					}
				},
				"source": [
					"## Writing Data from Synapse"
				]
			},
			{
				"cell_type": "code",
				"source": [
					"# 1. Define your target table path (<DatabaseName>.<SchemaName>.<TableName>)\n",
					"# Note: Ensure the schema (e.g., 'dbo') exists in your 'dedsqlwh' database.\n",
					"target_table = \"dedsqlwh.dbo.tbl3\"\n",
					"\n",
					"# 2. Write the data using the native, token-authenticated connector\n",
					"df.write \\\n",
					"    .format(\"com.microsoft.spark.sqlanalytics\") \\\n",
					"    .mode(\"overwrite\") \\\n",
					"    .synapsesql(target_table)"
				],
				"execution_count": 8
			}
		]
