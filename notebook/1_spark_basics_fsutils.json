				"source": [
					"# 1.Sales Data Analysis using Spark\n",
					"\n",
					"## Objective\n",
					"Analyze sales trends\n",
					"\n",
					"### Steps\n",
					"- Load data from ADLS\n",
					"- Transform using Spark\n",
					"- Generate KPIs\n",
					"\n",
					"### Code\n",
					"\n",
					"```python\n",
					"df = spark.read.csv(\"abfss://container/file.csv\")\n",
					"print(\"Hello\") \n",
					"print(\"World\")\n",
					"```\n",
					""
				]
			},
			{
				"cell_type": "code",
				"source": [
					"#Read from Data Lake\n",
					"df = spark.read.format(\"csv\").option(\"inferschema\",True).load(\"abfss://container1@we47storage1.dfs.core.windows.net/sourcedir/txns\") \\\n",
					".toDF(\"txnid\",\"txndate\",\"custid\",\"amount\",\"category\",\"product\",\"city\",\"state\",\"paytype\")\n",
					"df.printSchema()\n",
					"df.show(2)"
				],
				"execution_count": 1
			},
			{
				"cell_type": "code",
				"source": [
					"df.write.mode(\"overwrite\").saveAsTable(\"default.txnstbl\")"
				],
				"execution_count": 5
			},
			{
				"cell_type": "code",
				"source": [
					"df1 = df.filter(\"state = 'Texas' and paytype = 'credit'\")\n",
					"df1.show()"
				],
				"execution_count": null
			},
			{
				"cell_type": "code",
				"source": [
					"from pyspark.sql.functions import count,sum,round\n",
					"df1 = df.groupBy(\"state\").agg(count(\"txnid\").alias(\"TotalTrans\"),round(sum(\"amount\"),2).alias(\"TotalSales\"))\n",
					"df1.show()"
				],
				"execution_count": null
			},
			{
				"cell_type": "code",
				"source": [
					"#Write into ADLS\n",
					"df1.write.format(\"parquet\").save(\"abfss://container1@we47storage1.dfs.core.windows.net/outputdir/\")\n",
					"print(\"Data Written into Data Lake\")"
				],
				"execution_count": null
			},
			{
				"cell_type": "code",
				"source": [
					"#Read from data lake(External Storage) using Managed Identity\n",
					"\n",
					"#Provide Storage blob data contributor access to the synapse workspace idenitity\n",
					"\n",
					"# Ensure the path matches the account name above\n",
					"path = \"abfss://container1@we47storage1.dfs.core.windows.net/sourcedir/txns\"\n",
					"\n",
					"df = spark.read.format(\"csv\") \\\n",
					"    .option(\"header\", True) \\\n",
					"    .option(\"inferSchema\", True) \\\n",
					"    .load(path)\n",
					"df.show()"
				],
				"execution_count": null
			},
			{
				"cell_type": "markdown",
				"metadata": {
					"nteract": {
						"transient": {
							"deleting": false
						}
					}
				},
				"source": [
					"### 2. mssparkutils - File System(mssparkutils.fs)"
				]
			},
			{
				"cell_type": "code",
				"source": [
					"#List files\n",
					"from notebookutils import mssparkutils\n",
					"lst = mssparkutils.fs.ls(\"abfss://container1@we47storage1.dfs.core.windows.net\")"
				],
				"execution_count": null
			},
			{
				"cell_type": "code",
				"source": [
					"#View file content\n",
					"mssparkutils.fs.head(\"abfss://container1@we47storage1.dfs.core.windows.net/sourcedir/txns\")"
				],
				"execution_count": null
			},
			{
				"cell_type": "code",
				"source": [
					"#Copy file\n",
					"mssparkutils.fs.cp(\"abfss://container1@we47storage1.dfs.core.windows.net/sourcedir/txns\", \"abfss://container1@we47storage1.dfs.core.windows.net/sourcedir/txnscp\")"
				],
				"execution_count": null
			},
			{
				"cell_type": "code",
				"source": [
					"#Delete file\n",
					"mssparkutils.fs.rm(\"abfss://container1@we47storage1.dfs.core.windows.net/sourcedir/txnscp\")"
				],
				"execution_count": null
			}
